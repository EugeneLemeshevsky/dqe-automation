import pytest
import pandas as pd

# Fixture to read the CSV file
@pytest.fixture(scope="session")
def csv_data():
    path_to_file = r"C:\Test Automation DQE\dqe-automation\PyTest Introduction\src\data\data.csv"
    df = pd.read_csv(path_to_file)   
    return df

# Fixture to validate the schema of the file
@pytest.fixture(scope="session")
def validate_schema():
    def _validate(actual_schema, expected_schema):
        for column in expected_schema:
            assert column in actual_schema, f"Ошибка! Колонка '{column}' не найдена в файле"
        return True   
    return _validate

# Pytest hook to mark unmarked tests with a custom mark
def pytest_collection_modifyitems(items):
    for item in items:
        if not list(item.iter_markers()):
            item.add_marker(pytest.mark.unmarked)